    return false;
    #end
  }

  public static function iterable(value:Dynamic):Array<Dynamic> {
    #if js
    return js.Syntax.code('Array.from({0})', value);
    #else
    if (value == null) return [];
    if (Std.isOfType(value, Array)) return cast value;
    try {
      return (cast value : Array<Dynamic>).copy();
    } catch (_:Dynamic) {}
    final iterator = Reflect.callMethod(value, Reflect.field(value, 'iterator'), []);
    final output:Array<Dynamic> = [];
    while (Reflect.callMethod(iterator, Reflect.field(iterator, 'hasNext'), [])) {
      output.push(Reflect.callMethod(iterator, Reflect.field(iterator, 'next'), []));
    }
    return output;
    #end
  }

  public static inline function jsonParse(value:String):Dynamic {
    return haxe.Json.parse(value);
  }

  public static function jsonStringify(value:Dynamic, ?replacer:Dynamic, ?space:Dynamic):String {
    #if js
    return js.Syntax.code('JSON.stringify({0}, {1} ?? null, {2} ?? undefined)', value, replacer, space);
    #else
    return haxe.Json.stringify(value, replacer == null ? null : cast replacer, space == null ? null : Std.string(space));
    #end
  }

  public static function objectEntries(source:Dynamic):Array<Array<Dynamic>> {
    return [for (field in Reflect.fields(source)) [field, Reflect.field(source, field)]];
  }

  public static inline function orValue(left:Dynamic, right:Void->Dynamic):Dynamic {
    return truthy(left) ? left : right();
  }

  public static function padStart(value:String, length:Float, pad = ' '):String {
    var output = value;
    while (output.length < Std.int(length)) output = pad + output;
    return output.length > Std.int(length) ? output.substr(output.length - Std.int(length)) : output;
  }

  public static function padEnd(value:String, length:Float, pad = ' '):String {
    var output = value;
    while (output.length < Std.int(length)) output += pad;
    return output.length > Std.int(length) ? output.substr(0, Std.int(length)) : output;
  }

  public static function pushMany<T>(values:Array<T>, additions:Array<T>):Int {
    for (value in additions) values.push(value);
    return values.length;
  }

  public static function repeat(value:String, count:Float):String {
    return [for (_ in 0...Std.int(count)) value].join('');
  }

  public static function setInterval(callback:Void->Void, delayMs:Float):Dynamic {
    #if js
    return js.Syntax.code('globalThis.setInterval({0}, {1})', callback, delayMs);
    #else
    return haxe.Timer.delay(callback, Std.int(delayMs));
    #end
  }

  public static function toFixed(value:Float, digits:Float):String {
    #if js
    return js.Syntax.code('{0}.toFixed({1})', value, digits);
    #else
    final precision = HxMath.pow(10, digits);
    return Std.string(HxMath.round(value * precision) / precision);
    #end
  }

  public static inline function typeError(message:String):Dynamic {
    #if js
    return new js.lib.Error.TypeError(message);
    #else
    return new haxe.Exception(message);
    #end
  }

  public static inline function unsignedShiftRight(value:Int, bits:Int):Float {
    final shifted = value >>> bits;
    return bits == 0 && shifted < 0 ? shifted + 4294967296.0 : shifted;
  }

  public static function warn(values:Array<Dynamic>):Void {
    #if js
    js.Syntax.code('console.warn(...{0})', values);
    #else
    Sys.println(values.map(Std.string).join(' '));
    #end
  }
}
