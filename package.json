{
  "name": "flight-hx",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "api": "tsx generator/src/cli.ts --api",
    "api:check": "tsx generator/src/cli.ts --api --check",
    "api:json": "tsx generator/src/cli.ts --api --json",
    "build": "tsc -p tsconfig.build.json",
    "build:check": "tsc -p tsconfig.json --noEmit",
    "build:haxe:js": "node tooling/haxe.mjs -cp src -cp tests/haxe --main JsEntry --js build/haxe-js/flight.cjs -D js-es=6 --macro \"include('flighthq')\"",
    "check": "npm run generate:check && npm run typecheck && npm run lint && npm run format:check && npm run api:check",
    "ci": "npm run build && npm run check && npm run test && npm run package",
    "clean": "node -e \"for (const path of ['dist', 'build', 'coverage']) require('fs').rmSync(path, { force: true, recursive: true })\"",
    "example": "node tooling/run-example.mjs",
    "fix": "npm run lint:fix && npm run format",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "generate": "tsx generator/src/cli.ts",
    "generate:check": "tsx generator/src/cli.ts --check",
    "haxe": "node tooling/haxe.mjs",
    "haxe:version": "node tooling/haxe.mjs --version",
    "lint": "oxlint --max-warnings=0",
    "lint:fix": "oxlint --fix --max-warnings=0",
    "package": "node tooling/package-haxelib.mjs",
    "setup": "node tooling/setup-haxe.mjs",
    "test": "npm run test:unit && npm run test:haxe:all && npm run test:portable && npm run test:upstream",
    "test:coverage": "vitest run --coverage",
    "test:generator": "vitest run tests/generator",
    "test:haxe:all": "node tooling/haxe.mjs -cp src -cp tests/haxe --main CoreSmoke --interp --macro \"include('flighthq')\"",
    "test:haxe:core": "node tooling/haxe.mjs -cp src -cp tests/haxe --main CoreSmoke --interp",
    "test:portable": "node tooling/test-portable.mjs",
    "test:portable:cpp": "node tooling/test-portable.mjs cpp",
    "test:portable:eval": "node tooling/test-portable.mjs eval",
    "test:portable:js": "node tooling/test-portable.mjs js",
    "test:portable:python": "node tooling/test-portable.mjs python",
    "test:unit": "vitest run",
    "test:upstream": "npm run build:haxe:js && node tooling/test-upstream.mjs",
    "test:upstream:math": "npm run build:haxe:js && node tooling/test-upstream.mjs --package math",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "22.19.7",
    "@vitest/coverage-v8": "4.1.10",
    "jsdom": "^27.4.0",
    "lix": "16.0.2",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "vitest": "4.1.10",
    "vitest-webgl-canvas-mock": "^1.1.0",
    "yazl": "3.3.1"
  }
}
